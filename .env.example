# ============================================================
#  Leads del formulario de contacto
#  Copiá estas variables en Vercel → Project → Settings → Environment Variables
# ============================================================

# --- Email (Resend) ---
# API key de https://resend.com (Dashboard → API Keys)
RESEND_API_KEY=

# A quién le llegan los avisos de cada consulta
LEADS_EMAIL_TO=contacto@casinospuntadeleste.com

# Remitente. Debe ser una dirección de un dominio VERIFICADO en Resend.
# Hasta verificar el dominio, dejalo en el sandbox: onboarding@resend.dev
LEADS_EMAIL_FROM="Casinos Punta del Este <onboarding@resend.dev>"

# --- Base de datos (Postgres) ---
# Se inyecta automáticamente al crear un store de Postgres en Vercel
# (Storage → Create → Postgres). No hace falta cargarla a mano en Vercel.
POSTGRES_URL=
